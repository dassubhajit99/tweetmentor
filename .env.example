# Copy this file to `.env` and fill in your values. `.env` is gitignored.
# The analysis step uses any OpenAI-compatible endpoint (bring your own key).

# Required to run `tweetmentor analyze`.
LLM_API_KEY=your-api-key-here

# Optional. Defaults to the NVIDIA integrate API.
# Examples:
#   OpenAI:     https://api.openai.com/v1
#   NVIDIA:     https://integrate.api.nvidia.com/v1
#   Groq:       https://api.groq.com/openai/v1
#   Anthropic:  https://api.anthropic.com/v1/   (OpenAI-compat layer; keep the trailing slash)
LLM_BASE_URL=https://integrate.api.nvidia.com/v1

# Optional. Must be a model id your key/endpoint actually serves.
# Examples by provider:
#   NVIDIA:     nvidia/nemotron-3-super-120b-a12b
#   OpenAI:     gpt-4.1
#   Groq:       llama-3.3-70b-versatile
#   Anthropic:  claude-sonnet-4-5
LLM_MODEL=nvidia/nemotron-3-super-120b-a12b
